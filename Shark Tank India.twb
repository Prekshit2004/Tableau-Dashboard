      <column caption='Revenue Category' datatype='string' name='[Calculation_0607489438355456]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Yearly Revenue] &lt;= 10 THEN &quot;0-10 Lakhs&quot;&#13;&#10;ELSEIF [Yearly Revenue] &lt;= 50 THEN &quot;10-50 Lakhs&quot;&#13;&#10;ELSEIF [Yearly Revenue] &lt;= 100 THEN &quot;50-100 Lakhs&quot;&#13;&#10;ELSE &quot;100+ Lakhs&quot;&#13;&#10;END' />
      </column>
      <column caption='Funded Pitches(in%)' datatype='real' name='[Calculation_0607489439207425]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNT([Accepted Offer])/COUNT([Pitch Number]))*100' />
